@model ErrorViewModel
@{
    ViewData["Title"] = "خطأ";
}

<h1 class="text-danger">حدث خطأ.</h1>
<h2 class="text-danger">حدث خطأ أثناء معالجة طلبك.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>رقم الطلب:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>وضع التطوير</h3>
<p>
    التبديل إلى بيئة <strong>Development</strong> يعرض معلومات تفصيلية أكثر عن الخطأ الذي حدث.
</p>
<p>
    <strong>لا يجب تفعيل بيئة التطوير في التطبيقات المنشورة.</strong>
    قد يؤدي ذلك إلى عرض معلومات حساسة للمستخدمين.
    للتصحيح المحلي، فعّل بيئة <strong>Development</strong> من خلال ضبط متغير البيئة <strong>ASPNETCORE_ENVIRONMENT</strong> على القيمة <strong>Development</strong>
    ثم أعد تشغيل التطبيق.
</p>
