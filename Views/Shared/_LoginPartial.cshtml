@using Microsoft.AspNetCore.Identity
@using ParkingReservation.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@{
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<ul class="navbar-nav site-auth">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
    var isAdmin = User.IsInRole(UserRoles.Admin);
    @if (!isAdmin)
    {
        <li class="nav-item">
            <a class="nav-link site-user-link" asp-controller="Profile" asp-action="Index" asp-area="">
                <i class="bi bi-person-circle me-1"></i>@(user?.FullName ?? User.Identity?.Name)
            </a>
        </li>
    }
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn site-auth-btn site-auth-ghost">تسجيل الخروج</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn site-auth-btn site-auth-primary" asp-area="Identity" asp-page="/Account/Register"
           asp-route-returnUrl="@currentUrl">إنشاء حساب</a>
    </li>
    <li class="nav-item">
        <a class="btn site-auth-btn site-auth-ghost" asp-area="Identity" asp-page="/Account/Login"
           asp-route-returnUrl="@currentUrl">تسجيل الدخول</a>
    </li>
}
</ul>
