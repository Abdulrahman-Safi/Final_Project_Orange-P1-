@model ParkingLot
@{
    ViewData["Title"] = Model.Name;
    var availableSpots = Model.ParkingSpots
        .Where(spot => spot.IsActive && spot.Status == ParkingSpotStatus.Available)
        .OrderBy(spot => spot.SpotNumber)
        .ToList();
}

<div class="d-flex justify-content-between align-items-start gap-3 mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.Name</h1>
        <p class="text-muted mb-0">@Model.Address, @Model.City</p>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index">Back</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="border rounded p-3 h-100 bg-white">
            <div class="text-muted">Hourly rate</div>
            <div class="fs-4 fw-semibold">@Model.HourlyRate.ToString("0.00")</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100 bg-white">
            <div class="text-muted">Working hours</div>
            <div class="fs-5 fw-semibold">
                @Model.OpeningTime.ToString(@"hh\:mm") - @Model.ClosingTime.ToString(@"hh\:mm")
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="border rounded p-3 h-100 bg-white">
            <div class="text-muted">Available spots</div>
            <div class="fs-4 fw-semibold">@availableSpots.Count</div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Description))
{
    <div class="border rounded p-3 bg-white mb-4">
        <h2 class="h5">Description</h2>
        <p class="mb-0">@Model.Description</p>
    </div>
}

<div class="border rounded bg-white">
    <div class="p-3 border-bottom">
        <h2 class="h5 mb-0">Available spots</h2>
    </div>

    @if (!availableSpots.Any())
    {
        <div class="p-4 text-center">
            <div class="fw-semibold mb-1">No spots available now</div>
            <p class="text-muted mb-0">Please check another parking lot or try again later.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Spot number</th>
                        <th>Type</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var spot in availableSpots)
                {
                    <tr>
                        <td class="fw-semibold">@spot.SpotNumber</td>
                        <td>@spot.SpotType</td>
                        <td><span class="badge bg-success">@spot.Status</span></td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-primary" disabled>Reserve soon</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
