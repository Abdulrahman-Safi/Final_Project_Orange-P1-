        ["مرسيدس"] = new() { "C200", "C300", "E200", "E300", "S500", "GLC", "GLE", "GLS", "A200", "CLA" },
        ["بي إم دبليو"] = new() { "316i", "318i", "320i", "520i", "525i", "730i", "X3", "X5", "X6", "M3" },
        ["أودي"] = new() { "A3", "A4", "A6", "A8", "Q3", "Q5", "Q7", "Q8", "TT", "RS6" },
        ["لكزس"] = new() { "ES300", "ES350", "IS300", "RX350", "LX570", "GX460", "UX200", "NX300", "LS500", "LC500" },
