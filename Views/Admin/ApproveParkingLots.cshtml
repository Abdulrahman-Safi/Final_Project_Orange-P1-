@model IEnumerable<ParkingReservation.Models.ParkingLot>
@{
    ViewData["Title"] = "اعتماد المصفات";
    var selectedStatus = ViewBag.SelectedStatus == null ? (ParkingReservation.Models.ParkingLotStatus?)null : (ParkingReservation.Models.ParkingLotStatus)ViewBag.SelectedStatus;
    int pendingCount   = ViewBag.PendingCount;
    int approvedCount  = ViewBag.ApprovedCount;
    int rejectedCount  = ViewBag.RejectedCount;
    int suspendedCount = ViewBag.SuspendedCount;
}

<div class="admin-shell">
    <aside class="admin-sidebar">
        <div class="admin-sidebar-title">لوحة الإدارة</div>
        <a asp-action="Dashboard"><i class="bi bi-speedometer2"></i> لوحة التحكم</a>
        <a asp-action="Users"><i class="bi bi-people"></i> إدارة المستخدمين</a>
        <a class="active" asp-action="ApproveParkingLots"><i class="bi bi-p-square"></i> اعتماد المصفات</a>
        <a asp-action="Reservations"><i class="bi bi-calendar2-check"></i> متابعة الحجوزات</a>
    </aside>

    <main class="admin-main">
        <div class="admin-header">
            <div>
                <span>المصفات</span>
                <h1>اعتماد المصفات</h1>
                <p>مراجعة طلبات المصفات الجديدة واعتمادها أو رفضها أو تعليقها.</p>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="admin-kpi-grid" style="margin-bottom:1.5rem">
            <a class="admin-kpi @(selectedStatus == null ? "active" : "")"
               asp-action="ApproveParkingLots" style="text-decoration:none;cursor:pointer">
                <span>الكل</span><strong>@(pendingCount + approvedCount + rejectedCount + suspendedCount)</strong>
            </a>
            <a class="admin-kpi @(selectedStatus == ParkingLotStatus.Pending ? "active warning" : "warning")"
               asp-action="ApproveParkingLots" asp-route-status="@((int)ParkingLotStatus.Pending)"
               style="text-decoration:none;cursor:pointer">
                <span>قيد المراجعة</span><strong>@pendingCount</strong>
            </a>
            <a class="admin-kpi @(selectedStatus == ParkingLotStatus.Approved ? "active" : "")"
               asp-action="ApproveParkingLots" asp-route-status="@((int)ParkingLotStatus.Approved)"
               style="text-decoration:none;cursor:pointer">
                <span>معتمدة</span><strong>@approvedCount</strong>
            </a>
            <a class="admin-kpi @(selectedStatus == ParkingLotStatus.Rejected ? "active" : "")"
               asp-action="ApproveParkingLots" asp-route-status="@((int)ParkingLotStatus.Rejected)"
               style="text-decoration:none;cursor:pointer">
                <span>مرفوضة</span><strong>@rejectedCount</strong>
            </a>
            <a class="admin-kpi @(selectedStatus == ParkingLotStatus.Suspended ? "active" : "")"
               asp-action="ApproveParkingLots" asp-route-status="@((int)ParkingLotStatus.Suspended)"
               style="text-decoration:none;cursor:pointer">
                <span>معلّقة</span><strong>@suspendedCount</strong>
            </a>
        </div>

        <section class="admin-card admin-wide">
            @if (!Model.Any())
            {
                <div class="customer-empty customer-empty-panel">
                    <div class="customer-empty-title">لا توجد مصفات في هذه الفئة</div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-dashboard">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>اسم المصف</th>
                                <th>المالك</th>
                                <th>المدينة / المنطقة</th>
                                <th>المواقف</th>
                                <th>السعر/ساعة</th>
                                <th>الحالة</th>
                                <th>تاريخ الطلب</th>
                                <th class="text-end">الإجراءات</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lot in Model)
                            {
                                <tr>
                                    <td>@lot.Id</td>
                                    <td><strong>@lot.Name</strong></td>
                                    <td>
                                        @lot.Owner?.FullName
                                        <br /><small class="text-muted">@lot.Owner?.Email</small>
                                    </td>
                                    <td>
                                        @lot.City
                                        @if (!string.IsNullOrEmpty(lot.Area))
                                        {
                                            <br/><span class="lot-area-badge" style="font-size:.75rem"><i class="bi bi-geo-alt-fill me-1"></i>@lot.Area</span>
                                        }
                                    </td>
                                    <td>@lot.ParkingSpots.Count</td>
                                    <td>@lot.HourlyRate.ToString("0.00")</td>
                                    <td><span class="status-pill @GetStatusClass(lot.Status)">@GetStatusName(lot.Status)</span></td>
                                    <td>@lot.CreatedAt.ToString("yyyy/MM/dd")</td>
                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-secondary me-1"
                                           asp-action="ParkingLotDetails" asp-route-id="@lot.Id">
                                            <i class="bi bi-eye"></i> تفاصيل
                                        </a>
                                        @if (lot.Status != ParkingLotStatus.Approved)
                                        {
                                            <form asp-action="ChangeParkingLotStatus" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@lot.Id" />
                                                <input type="hidden" name="status" value="@((int)ParkingLotStatus.Approved)" />
                                                <button type="submit" class="btn btn-sm btn-success me-1">
                                                    <i class="bi bi-check-lg"></i> اعتماد
                                                </button>
                                            </form>
                                        }
                                        @if (lot.Status != ParkingLotStatus.Rejected)
                                        {
                                            <form asp-action="ChangeParkingLotStatus" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@lot.Id" />
                                                <input type="hidden" name="status" value="@((int)ParkingLotStatus.Rejected)" />
                                                <button type="submit" class="btn btn-sm btn-danger me-1">
                                                    <i class="bi bi-x-lg"></i> رفض
                                                </button>
                                            </form>
                                        }
                                        @if (lot.Status == ParkingLotStatus.Approved)
                                        {
                                            <form asp-action="ChangeParkingLotStatus" method="post" class="d-inline">
                                                <input type="hidden" name="id" value="@lot.Id" />
                                                <input type="hidden" name="status" value="@((int)ParkingLotStatus.Suspended)" />
                                                <button type="submit" class="btn btn-sm btn-warning">
                                                    <i class="bi bi-pause-circle"></i> تعليق
                                                </button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </main>
</div>

@functions {
    private static string GetStatusClass(ParkingLotStatus status) => status switch
    {
        ParkingLotStatus.Pending   => "status-pending",
        ParkingLotStatus.Approved  => "status-approved",
        ParkingLotStatus.Rejected  => "status-rejected",
        ParkingLotStatus.Suspended => "status-suspended",
        _ => ""
    };

    private static string GetStatusName(ParkingLotStatus status) => status switch
    {
        ParkingLotStatus.Pending   => "قيد المراجعة",
        ParkingLotStatus.Approved  => "معتمد",
        ParkingLotStatus.Rejected  => "مرفوض",
        ParkingLotStatus.Suspended => "معلّق",
        _ => status.ToString()
    };
}
