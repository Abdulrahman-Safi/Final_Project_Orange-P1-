@model ParkingReservation.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "لوحة تحكم الإدارة";
    var maxUsers = Math.Max(1, Model.NewUsersGrowth.Any() ? Model.NewUsersGrowth.Max(item => item.Value) : 1);
    var maxReservations = Math.Max(1, Model.ReservationsStatistics.Any() ? Model.ReservationsStatistics.Max(item => item.Value) : 1);
    var maxRevenue = Math.Max(1, Model.RevenueAnalytics.Any() ? Model.RevenueAnalytics.Max(item => item.Value) : 1);
}

<div class="admin-shell">
    <aside class="admin-sidebar">
        <div class="admin-sidebar-title">لوحة الإدارة</div>
        <a class="active" asp-action="Dashboard"><i class="bi bi-speedometer2"></i> لوحة التحكم</a>
        <a asp-action="Users"><i class="bi bi-people"></i> إدارة المستخدمين</a>
        <a asp-action="ApproveParkingLots"><i class="bi bi-p-square"></i> اعتماد المصفات</a>
        <a asp-action="Reservations"><i class="bi bi-calendar2-check"></i> متابعة الحجوزات</a>
    </aside>

    <main class="admin-main">
        <div class="admin-header">
            <div>
                <span>مركز التحكم بالنظام</span>
                <h1>لوحة تحكم الإدارة</h1>
                <p>تابع المستخدمين وأصحاب المواقف والمصفات والموافقات والحجوزات وتحليلات الإيرادات.</p>
            </div>
        </div>

        <div class="admin-kpi-grid">
            <div class="admin-kpi"><span>إجمالي المستخدمين</span><strong>@Model.TotalUsersCount</strong></div>
            <div class="admin-kpi"><span>إجمالي أصحاب المواقف</span><strong>@Model.TotalOwnersCount</strong></div>
            <div class="admin-kpi"><span>إجمالي المصفات</span><strong>@Model.TotalParkingLotsCount</strong></div>
            <div class="admin-kpi"><span>إجمالي الحجوزات</span><strong>@Model.TotalReservationsCount</strong></div>
            <div class="admin-kpi warning"><span>طلبات بانتظار الموافقة</span><strong>@Model.PendingParkingLotsCount</strong></div>
        </div>

        <div class="admin-grid">
            <section class="admin-card">
                <h2>نمو المستخدمين الجدد</h2>
                <div class="admin-chart">
                    @foreach (var item in Model.NewUsersGrowth)
                    {
                        var height = Math.Max(8, (int)(item.Value / maxUsers * 100));
                        <div><span style="height:@height%"></span><small>@item.Label</small></div>
                    }
                </div>
            </section>

            <section class="admin-card">
                <h2>إحصائيات الحجوزات</h2>
                <div class="admin-chart teal">
                    @foreach (var item in Model.ReservationsStatistics)
                    {
                        var height = Math.Max(8, (int)(item.Value / maxReservations * 100));
                        <div><span style="height:@height%"></span><small>@item.Label</small></div>
                    }
                </div>
            </section>

            <section class="admin-card">
                <h2>تحليلات الإيرادات</h2>
                <div class="admin-chart green">
                    @foreach (var item in Model.RevenueAnalytics)
                    {
                        var height = Math.Max(8, (int)(item.Value / maxRevenue * 100));
                        <div><span style="height:@height%"></span><small>@item.Label</small></div>
                    }
                </div>
            </section>

            <section class="admin-card admin-wide">
                <div class="admin-card-header">
                    <h2>قائمة الموافقات</h2>
                    <a asp-action="Dashboard" asp-route-status="@ParkingLotStatus.Pending">عرض المعلّقة</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-dashboard">
                        <thead><tr><th>المصف</th><th>المالك</th><th>المدينة</th><th>الحالة</th><th class="text-end">الإجراءات</th></tr></thead>
                        <tbody>
                        @foreach (var lot in Model.ParkingLots.Take(8))
                        {
                            <tr>
                                <td>@lot.Name</td>
                                <td>@lot.Owner?.FullName</td>
                                <td>@lot.City</td>
                                <td><span class="status-pill @GetStatusClass(lot.Status)">@GetStatusName(lot.Status)</span></td>
                                <td class="text-end"><a class="btn btn-sm btn-outline-secondary" asp-action="ParkingLotDetails" asp-route-id="@lot.Id">التفاصيل</a></td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="admin-card">
                <h2>آخر التسجيلات</h2>
                @foreach (var user in Model.RecentUsers)
                {
                    <div class="admin-list-item"><strong>@user.FullName</strong><span>@user.Email</span></div>
                }
            </section>

            <section class="admin-card">
                <h2>المصفات المضافة حديثاً</h2>
                @foreach (var lot in Model.RecentlyAddedParkingLots)
                {
                    <div class="admin-list-item"><strong>@lot.Name</strong><span>@lot.Owner?.Email</span></div>
                }
            </section>

            <section class="admin-card">
                <h2>سجل النشاط</h2>
                @foreach (var log in Model.ActivityLogs)
                {
                    <div class="admin-log-item">@log</div>
                }
            </section>
        </div>
    </main>
</div>

@functions {
    private static string GetStatusClass(ParkingLotStatus status)
    {
        return status switch
        {
            ParkingLotStatus.Pending => "status-pending",
            ParkingLotStatus.Approved => "status-approved",
            ParkingLotStatus.Rejected => "status-rejected",
            ParkingLotStatus.Suspended => "status-suspended",
            _ => "status-suspended"
        };
    }

    private static string GetStatusName(ParkingLotStatus status)
    {
        return status switch
        {
            ParkingLotStatus.Pending => "قيد المراجعة",
            ParkingLotStatus.Approved => "معتمد",
            ParkingLotStatus.Rejected => "مرفوض",
            ParkingLotStatus.Suspended => "معلّق",
            _ => status.ToString()
        };
    }
}
