@model ParkingLot
@{
    ViewData["Title"] = "تفاصيل المصف";
}

<div class="page-shell">
    <div class="dashboard-header">
        <div>
            <h1 class="dashboard-title">@Model.Name</h1>
            <p class="dashboard-subtitle">@Model.Address، @Model.City</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Dashboard">رجوع</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="detail-card">
                <h2>بيانات المصف</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">الحالة</dt>
                    <dd class="col-sm-8"><span class="status-pill @GetStatusClass(Model.Status)">@GetStatusName(Model.Status)</span></dd>
                    <dt class="col-sm-4">سعر الساعة</dt>
                    <dd class="col-sm-8">@Model.HourlyRate.ToString("0.00")</dd>
                    <dt class="col-sm-4">ساعات العمل</dt>
                    <dd class="col-sm-8">@Model.OpeningTime - @Model.ClosingTime</dd>
                    <dt class="col-sm-4">الوصف</dt>
                    <dd class="col-sm-8">@(Model.Description ?? "لا يوجد وصف")</dd>
                </dl>
            </div>
        </div>
        <div class="col-md-6">
            <div class="detail-card">
                <h2>صاحب المصف</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">الاسم</dt>
                    <dd class="col-sm-8">@Model.Owner?.FullName</dd>
                    <dt class="col-sm-4">البريد</dt>
                    <dd class="col-sm-8">@Model.Owner?.Email</dd>
                    <dt class="col-sm-4">الهاتف</dt>
                    <dd class="col-sm-8">@(Model.Owner?.PhoneNumber ?? "غير متوفر")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="content-panel mb-4">
        <div class="panel-header">
            <h2 class="panel-title">إجراءات الحالة</h2>
        </div>
        <div class="p-3 d-flex flex-wrap gap-2">
            <form asp-action="ChangeParkingLotStatus" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="status" value="@ParkingLotStatus.Approved" />
                <button type="submit" class="btn btn-success">موافقة</button>
            </form>
            <form asp-action="ChangeParkingLotStatus" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="status" value="@ParkingLotStatus.Rejected" />
                <button type="submit" class="btn btn-danger">رفض</button>
            </form>
            <form asp-action="ChangeParkingLotStatus" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="status" value="@ParkingLotStatus.Suspended" />
                <button type="submit" class="btn btn-warning">تعليق</button>
            </form>
        </div>
    </div>

    <div class="content-panel">
        <div class="panel-header">
            <h2 class="panel-title">المواقف</h2>
        </div>

        @if (!Model.ParkingSpots.Any())
        {
            <div class="empty-state">
                <div class="empty-state-title">لم تتم إضافة مواقف بعد</div>
                <p class="empty-state-text">يمكن لصاحب المصف إضافة المواقف من لوحة المالك.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-dashboard">
                    <thead>
                        <tr>
                            <th>رقم الموقف</th>
                            <th>النوع</th>
                            <th>الحالة</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var spot in Model.ParkingSpots)
                    {
                        <tr>
                            <td class="fw-semibold">@spot.SpotNumber</td>
                            <td>@GetSpotTypeName(spot.SpotType)</td>
                            <td><span class="status-pill @GetSpotStatusClass(spot.Status)">@GetSpotStatusName(spot.Status)</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    private static string GetStatusClass(ParkingLotStatus status)
    {
        return status switch
        {
            ParkingLotStatus.Pending => "status-pending",
            ParkingLotStatus.Approved => "status-approved",
            ParkingLotStatus.Rejected => "status-rejected",
            ParkingLotStatus.Suspended => "status-suspended",
            _ => "status-suspended"
        };
    }

    private static string GetStatusName(ParkingLotStatus status)
    {
        return status switch
        {
            ParkingLotStatus.Pending => "قيد المراجعة",
            ParkingLotStatus.Approved => "معتمد",
            ParkingLotStatus.Rejected => "مرفوض",
            ParkingLotStatus.Suspended => "معلق",
            _ => status.ToString()
        };
    }

    private static string GetSpotStatusClass(ParkingSpotStatus status)
    {
        return status switch
        {
            ParkingSpotStatus.Available => "status-approved",
            ParkingSpotStatus.Reserved => "status-pending",
            ParkingSpotStatus.Occupied => "status-rejected",
            ParkingSpotStatus.Maintenance => "status-suspended",
            _ => "status-suspended"
        };
    }

    private static string GetSpotStatusName(ParkingSpotStatus status)
    {
        return status switch
        {
            ParkingSpotStatus.Available => "متاح",
            ParkingSpotStatus.Reserved => "محجوز",
            ParkingSpotStatus.Occupied => "مشغول",
            ParkingSpotStatus.Maintenance => "صيانة",
            _ => status.ToString()
        };
    }

    private static string GetSpotTypeName(ParkingSpotType type)
    {
        return type switch
        {
            ParkingSpotType.Standard => "عادي",
            ParkingSpotType.Disabled => "ذوي الإعاقة",
            ParkingSpotType.Electric => "كهربائي",
            ParkingSpotType.VIP => "VIP",
            _ => type.ToString()
        };
    }
}
