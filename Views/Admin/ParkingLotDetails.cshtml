@model ParkingLot
@{
    ViewData["Title"] = "Parking Lot Details";
}

<div class="page-shell">
    <div class="dashboard-header">
        <div>
            <h1 class="dashboard-title">@Model.Name</h1>
            <p class="dashboard-subtitle">@Model.Address, @Model.City</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Dashboard">Back</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-6">
            <div class="detail-card">
                <h2>Parking lot</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8"><span class="status-pill @GetStatusClass(Model.Status)">@Model.Status</span></dd>
                    <dt class="col-sm-4">Hourly rate</dt>
                    <dd class="col-sm-8">@Model.HourlyRate.ToString("0.00")</dd>
                    <dt class="col-sm-4">Opening</dt>
                    <dd class="col-sm-8">@Model.OpeningTime - @Model.ClosingTime</dd>
                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@(Model.Description ?? "No description")</dd>
                </dl>
            </div>
        </div>
        <div class="col-md-6">
            <div class="detail-card">
                <h2>Owner</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Owner?.FullName</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Owner?.Email</dd>
                    <dt class="col-sm-4">Phone</dt>
                    <dd class="col-sm-8">@(Model.Owner?.PhoneNumber ?? "Not provided")</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="content-panel mb-4">
        <div class="panel-header">
            <h2 class="panel-title">Status actions</h2>
        </div>
        <div class="p-3 d-flex flex-wrap gap-2">
            <form asp-action="ChangeParkingLotStatus" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="status" value="@ParkingLotStatus.Approved" />
                <button type="submit" class="btn btn-success">Approve</button>
            </form>
            <form asp-action="ChangeParkingLotStatus" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="status" value="@ParkingLotStatus.Rejected" />
                <button type="submit" class="btn btn-danger">Reject</button>
            </form>
            <form asp-action="ChangeParkingLotStatus" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="status" value="@ParkingLotStatus.Suspended" />
                <button type="submit" class="btn btn-warning">Suspend</button>
            </form>
        </div>
    </div>

    <div class="content-panel">
        <div class="panel-header">
            <h2 class="panel-title">Parking spots</h2>
        </div>

        @if (!Model.ParkingSpots.Any())
        {
            <div class="empty-state">
                <div class="empty-state-title">No spots have been added yet</div>
                <p class="empty-state-text">The owner can add spots from the owner dashboard.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-dashboard">
                    <thead>
                        <tr>
                            <th>Spot number</th>
                            <th>Type</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var spot in Model.ParkingSpots)
                    {
                        <tr>
                            <td class="fw-semibold">@spot.SpotNumber</td>
                            <td>@spot.SpotType</td>
                            <td><span class="status-pill status-suspended">@spot.Status</span></td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@functions {
    private static string GetStatusClass(ParkingLotStatus status)
    {
        return status switch
        {
            ParkingLotStatus.Pending => "status-pending",
            ParkingLotStatus.Approved => "status-approved",
            ParkingLotStatus.Rejected => "status-rejected",
            ParkingLotStatus.Suspended => "status-suspended",
            _ => "status-suspended"
        };
    }
}
