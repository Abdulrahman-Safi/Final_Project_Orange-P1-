@model ParkingReservation.Models.ViewModels.OwnerDashboardViewModel
@{
    ViewData["Title"] = "لوحة تحكم صاحب المصف";
    var maxReservations = Math.Max(1, Model.ReservationsPerDay.Any() ? Model.ReservationsPerDay.Max(item => item.Value) : 1);
    var maxRevenue = Math.Max(1, Model.RevenuePerMonth.Any() ? Model.RevenuePerMonth.Max(item => item.Value) : 1);
}

<div class="owner-shell owner-business">
    <div class="owner-header owner-business-header">
        <div>
            <div class="owner-kicker">إدارة الأعمال</div>
            <h1 class="owner-title">لوحة تحكم صاحب المصف</h1>
            <p class="owner-subtitle">أدر المصفات والموافقات والحجوزات والإيرادات الشهرية.</p>
        </div>
        <div class="owner-action-row">
            <a class="btn owner-primary-btn" asp-action="CreateParkingLot"><i class="bi bi-plus-circle"></i> إضافة مصف</a>
            <a class="btn btn-outline-secondary" asp-action="Reservations"><i class="bi bi-calendar-check"></i> عرض الحجوزات</a>
        </div>
    </div>

    <div class="owner-kpi-grid">
        <div class="owner-kpi-card">
            <div class="owner-kpi-icon" style="background:#e7f1ff;color:#0d6efd"><i class="bi bi-p-square-fill"></i></div>
            <div class="owner-kpi-body"><span>إجمالي المصفات</span><strong>@Model.ParkingLotsCount</strong></div>
        </div>
        <div class="owner-kpi-card">
            <div class="owner-kpi-icon" style="background:#ccfbf1;color:#0d9488"><i class="bi bi-grid-3x3-gap-fill"></i></div>
            <div class="owner-kpi-body"><span>إجمالي المواقف</span><strong>@Model.ParkingSpotsCount</strong></div>
        </div>
        <div class="owner-kpi-card">
            <div class="owner-kpi-icon" style="background:#d1fae5;color:#059669"><i class="bi bi-calendar-check-fill"></i></div>
            <div class="owner-kpi-body"><span>الحجوزات النشطة</span><strong>@Model.ActiveReservationsCount</strong></div>
        </div>
        <div class="owner-kpi-card">
            <div class="owner-kpi-icon" style="background:#fef9c3;color:#ca8a04"><i class="bi bi-cash-coin"></i></div>
            <div class="owner-kpi-body"><span>إيراد الشهر</span><strong>@Model.MonthlyRevenue.ToString("0.00") <small style="font-size:.9rem;font-weight:600;color:#667085">د.أ</small></strong></div>
        </div>
    </div>

    <div class="owner-dashboard-grid">
        <section class="owner-widget">
            <div class="owner-widget-header"><h2>الحجوزات اليومية</h2></div>
            <div class="mini-chart">
                @foreach (var item in Model.ReservationsPerDay)
                {
                    var height = Math.Max(8, (int)(item.Value / maxReservations * 100));
                    <div class="mini-chart-bar">
                        <span style="height:@height%"></span>
                        <small>@item.Label</small>
                    </div>
                }
            </div>
        </section>

        <section class="owner-widget">
            <div class="owner-widget-header"><h2>الإيرادات الشهرية</h2></div>
            <div class="mini-chart revenue-chart">
                @foreach (var item in Model.RevenuePerMonth)
                {
                    var height = Math.Max(8, (int)(item.Value / maxRevenue * 100));
                    <div class="mini-chart-bar">
                        <span style="height:@height%"></span>
                        <small>@item.Label</small>
                    </div>
                }
            </div>
        </section>

        <section class="owner-widget owner-widget-wide">
            <div class="owner-widget-header">
                <h2>أحدث الحجوزات</h2>
                <a asp-action="Reservations">عرض الكل</a>
            </div>
            <div class="table-responsive">
                <table class="table owner-table">
                    <thead><tr><th>المستخدم</th><th>المصف</th><th>الموقف</th><th>الحالة</th><th>المبلغ</th></tr></thead>
                    <tbody>
                    @foreach (var reservation in Model.RecentReservations)
                    {
                        <tr>
                            <td>@reservation.User?.FullName</td>
                            <td>@reservation.ParkingSpot?.ParkingLot?.Name</td>
                            <td>@reservation.ParkingSpot?.SpotNumber</td>
                            <td>@GetReservationStatusName(reservation.Status)</td>
                            <td>@reservation.TotalPrice.ToString("0.00")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="owner-widget">
            <div class="owner-widget-header"><h2>أكثر المصفات حجزاً</h2></div>
            @foreach (var lot in Model.MostBookedParkingLots)
            {
                <div class="owner-list-item">
                    <strong>@lot.Name</strong>
                    <span>@lot.ParkingSpots.Count موقف</span>
                </div>
            }
        </section>

        <section class="owner-widget">
            <div class="owner-widget-header"><h2>ملخص الإيرادات</h2></div>
            <div class="revenue-summary">
                <span>إيراد هذا الشهر</span>
                <strong>@Model.MonthlyRevenue.ToString("0.00") <small style="font-size:1rem;font-weight:600;color:#667085">د.أ</small></strong>
                <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:.25rem">
                    <div style="font-size:.85rem;color:#667085">
                        <i class="bi bi-calendar-check me-1 text-success"></i>
                        الحجوزات النشطة: <strong style="color:#172033;font-size:.85rem">@Model.ActiveReservationsCount</strong>
                    </div>
                    <div style="font-size:.85rem;color:#667085">
                        <i class="bi bi-p-square me-1 text-primary"></i>
                        المصفات: <strong style="color:#172033;font-size:.85rem">@Model.ParkingLotsCount</strong>
                    </div>
                </div>
                <p style="margin-top:.5rem">يتم احتساب الإيراد من الحجوزات المؤكدة والمكتملة.</p>
            </div>
        </section>
    </div>
</div>

@functions {
    private static string GetReservationStatusName(ReservationStatus status)
    {
        return status switch
        {
            ReservationStatus.Pending => "بانتظار الموافقة",
            ReservationStatus.Confirmed => "مؤكد",
            ReservationStatus.Cancelled => "ملغي",
            ReservationStatus.Completed => "مكتمل",
            _ => status.ToString()
        };
    }
}
