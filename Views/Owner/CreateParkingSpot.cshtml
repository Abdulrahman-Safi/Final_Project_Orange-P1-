@model ParkingReservation.Models.ViewModels.ParkingSpotFormViewModel
@{
    ViewData["Title"] = "Add Parking Spot";
}

<div class="owner-shell">
    <div class="owner-header">
        <div>
            <div class="owner-kicker">New spot</div>
            <h1 class="owner-title">Add parking spot</h1>
            <p class="owner-subtitle">@Model.ParkingLotName</p>
        </div>
    </div>

    <div class="owner-form-panel">
        <form method="post" class="row g-3">
            <input asp-for="ParkingLotId" type="hidden" />
            <input asp-for="ParkingLotName" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="col-md-6">
                <label asp-for="SpotNumber" class="form-label"></label>
                <input asp-for="SpotNumber" class="form-control" />
                <span asp-validation-for="SpotNumber" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="SpotType" class="form-label"></label>
                <select asp-for="SpotType" class="form-select" asp-items="Html.GetEnumSelectList<ParkingSpotType>()"></select>
                <span asp-validation-for="SpotType" class="text-danger"></span>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn owner-primary-btn">Save</button>
                <a class="btn btn-outline-secondary" asp-action="ParkingSpots" asp-route-parkingLotId="@Model.ParkingLotId">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
