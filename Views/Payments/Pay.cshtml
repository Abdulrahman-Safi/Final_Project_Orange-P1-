@model ParkingReservation.Models.Reservation
@{
    ViewData["Title"] = "الدفع";
    var duration = Math.Ceiling((Model.EndTime - Model.StartTime).TotalHours);
}

<div class="customer-shell">

    <!-- Page header -->
    <div class="customer-header">
        <div>
            <div class="customer-kicker">إتمام الدفع</div>
            <h1 class="customer-title">بوابة الدفع الآمنة</h1>
            <p class="customer-subtitle">
                <i class="bi bi-shield-fill-check text-success me-1"></i>
                جلسة مشفرة وآمنة
            </p>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="Reservations" asp-action="MyReservations">
            <i class="bi bi-arrow-right me-1"></i> حجوزاتي
        </a>
    </div>

    <!-- 2-column checkout grid -->
    <div class="pay-checkout-grid">

        <!-- ══ LEFT: Order Summary ══ -->
        <aside class="pay-order-summary">
            <div class="pay-order-header">
                <i class="bi bi-receipt me-2"></i> ملخص الحجز
            </div>

            <div class="pay-order-lot">
                <div class="pay-order-lot-icon">
                    <i class="bi bi-p-square-fill"></i>
                </div>
                <div>
                    <div class="pay-order-lot-name">@Model.ParkingSpot?.ParkingLot?.Name</div>
                    <div class="pay-order-lot-spot">موقف رقم @Model.ParkingSpot?.SpotNumber</div>
                </div>
            </div>

            <div class="pay-order-rows">
                <div class="pay-order-row">
                    <span><i class="bi bi-calendar3 me-1"></i>تاريخ الحجز</span>
                    <strong>@Model.StartTime.ToString("yyyy/MM/dd")</strong>
                </div>
                <div class="pay-order-row">
                    <span><i class="bi bi-clock me-1"></i>من</span>
                    <strong>@Model.StartTime.ToString("HH:mm")</strong>
                </div>
                <div class="pay-order-row">
                    <span><i class="bi bi-clock-history me-1"></i>إلى</span>
                    <strong>@Model.EndTime.ToString("HH:mm")</strong>
                </div>
                <div class="pay-order-row">
                    <span><i class="bi bi-hourglass-split me-1"></i>المدة</span>
                    <strong>@duration ساعة</strong>
                </div>
            </div>

            <div class="pay-order-total">
                <span>المبلغ الإجمالي</span>
                <strong>@Model.TotalPrice.ToString("0.00") د.أ</strong>
            </div>

            <div class="pay-order-badges">
                <span><i class="bi bi-shield-check text-success me-1"></i>دفع مشفر</span>
                <span><i class="bi bi-patch-check text-warning me-1"></i>مصف معتمد</span>
            </div>
        </aside>

        <!-- ══ RIGHT: Payment Form ══ -->
        <div class="pay-shell">
            <form id="payForm" method="post">
                <input type="hidden" name="reservationId" value="@Model.Id" />
                <input type="hidden" id="methodInput" name="method" value="@((int)PaymentMethod.CreditCard)" />

                <!-- Method selector -->
                <div class="pay-methods-label">اختر طريقة الدفع</div>
                <div class="pay-methods">
                    <button type="button" class="pay-method-btn active"
                            data-method="@((int)PaymentMethod.CreditCard)" data-panel="panel-card">
                        <i class="bi bi-credit-card-2-front"></i>
                        <span>بطاقة ائتمان</span>
                    </button>
                    <button type="button" class="pay-method-btn"
                            data-method="@((int)PaymentMethod.PayPal)" data-panel="panel-paypal">
                        <i class="bi bi-paypal"></i>
                        <span>PayPal</span>
                    </button>
                    <button type="button" class="pay-method-btn"
                            data-method="@((int)PaymentMethod.Wallet)" data-panel="panel-wallet">
                        <i class="bi bi-wallet2"></i>
                        <span>المحفظة</span>
                    </button>
                </div>

                <!-- Credit card panel -->
                <div class="pay-panel active" id="panel-card">
                    <div class="pay-card-preview">
                        <div class="pay-card-chip"><i class="bi bi-cpu"></i></div>
                        <div class="pay-card-number" id="cardPreviewNumber">•••• •••• •••• ••••</div>
                        <div class="pay-card-bottom">
                            <div>
                                <div class="pay-card-label">اسم حامل البطاقة</div>
                                <div class="pay-card-value" id="cardPreviewName">الاسم الكامل</div>
                            </div>
                            <div>
                                <div class="pay-card-label">انتهاء الصلاحية</div>
                                <div class="pay-card-value" id="cardPreviewExpiry">MM/YY</div>
                            </div>
                        </div>
                    </div>
                    <div class="pay-form-grid">
                        <div class="pay-field pay-field-full">
                            <label>رقم البطاقة</label>
                            <div class="pay-input-icon">
                                <input type="text" id="cardNumber" class="form-control auth-input pay-sim-input"
                                       placeholder="1234 5678 9012 3456" maxlength="19" autocomplete="off" />
                                <i class="bi bi-credit-card pay-input-suffix"></i>
                            </div>
                        </div>
                        <div class="pay-field pay-field-full">
                            <label>اسم حامل البطاقة</label>
                            <input type="text" id="cardName" class="form-control auth-input pay-sim-input"
                                   placeholder="كما هو مكتوب على البطاقة" />
                        </div>
                        <div class="pay-field">
                            <label>تاريخ الانتهاء</label>
                            <input type="text" id="cardExpiry" class="form-control auth-input pay-sim-input"
                                   placeholder="MM/YY" maxlength="5" />
                        </div>
                        <div class="pay-field">
                            <label>رمز الأمان (CVV)</label>
                            <div class="pay-input-icon">
                                <input type="text" id="cardCvv" class="form-control auth-input pay-sim-input"
                                       placeholder="•••" maxlength="3" />
                                <i class="bi bi-shield-lock pay-input-suffix"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- PayPal panel -->
                <div class="pay-panel" id="panel-paypal">
                    <div class="pay-paypal-logo">
                        <i class="bi bi-paypal" style="font-size:3rem;color:#003087"></i>
                        <span>PayPal</span>
                    </div>
                    <div class="pay-form-grid">
                        <div class="pay-field pay-field-full">
                            <label>البريد الإلكتروني المرتبط بـ PayPal</label>
                            <div class="pay-input-icon">
                                <input type="email" class="form-control auth-input pay-sim-input"
                                       placeholder="example@paypal.com" />
                                <i class="bi bi-envelope pay-input-suffix"></i>
                            </div>
                        </div>
                        <div class="pay-field pay-field-full">
                            <label>كلمة المرور</label>
                            <div class="pay-input-icon">
                                <input type="password" class="form-control auth-input pay-sim-input"
                                       placeholder="••••••••" />
                                <i class="bi bi-lock pay-input-suffix"></i>
                            </div>
                        </div>
                    </div>
                    <div class="pay-sim-note">
                        <i class="bi bi-info-circle me-1"></i>
                        هذه بيئة محاكاة — لن يتم خصم أي مبلغ حقيقي.
                    </div>
                </div>

                <!-- Wallet panel -->
                <div class="pay-panel" id="panel-wallet">
                    <div class="pay-wallet-balance">
                        <span>رصيد محفظتك الحالي</span>
                        <strong>500.00 د.أ</strong>
                    </div>
                    <div class="pay-wallet-deduct">
                        <div class="pay-wallet-row">
                            <span>المبلغ المطلوب</span>
                            <strong>@Model.TotalPrice.ToString("0.00") د.أ</strong>
                        </div>
                        <div class="pay-wallet-row">
                            <span>الرصيد بعد الدفع</span>
                            <strong>@((500 - Model.TotalPrice).ToString("0.00")) د.أ</strong>
                        </div>
                    </div>
                    <div class="pay-sim-note">
                        <i class="bi bi-info-circle me-1"></i>
                        هذه بيئة محاكاة — الرصيد المعروض افتراضي فقط.
                    </div>
                </div>

                <!-- Submit -->
                <div class="pay-submit-row">
                    <div class="pay-secure-badge">
                        <i class="bi bi-shield-fill-check"></i>
                        <span>الدفع محمي ومشفر بالكامل (محاكاة)</span>
                    </div>
                    <button type="submit" class="btn customer-card-btn pay-submit-btn" id="payBtn">
                        <i class="bi bi-lock-fill me-1"></i>
                        ادفع @Model.TotalPrice.ToString("0.00") د.أ الآن
                    </button>
                </div>
            </form>
        </div>

    </div><!-- /pay-checkout-grid -->
</div>

<style>
    /* ── 2-column checkout grid ── */
    .pay-checkout-grid {
        display: grid;
        grid-template-columns: minmax(0, .42fr) minmax(0, .58fr);
        gap: 1.5rem;
        align-items: start;
    }

    /* ── Order summary (left column) ── */
    .pay-order-summary {
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,.05);
        position: sticky;
        top: 88px;
    }
    .pay-order-header {
        padding: 1rem 1.25rem;
        background: #f8f9fa;
        border-bottom: 1px solid #e9ecef;
        font-weight: 700;
        font-size: .95rem;
        color: #212529;
    }
    .pay-order-lot {
        display: flex;
        align-items: center;
        gap: .85rem;
        padding: 1.25rem;
        border-bottom: 1px solid #f0f0f0;
    }
    .pay-order-lot-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        background: #e7f1ff;
        color: #0d6efd;
        font-size: 1.4rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .pay-order-lot-name { font-weight: 700; color: #212529; font-size: .95rem; }
    .pay-order-lot-spot { color: #6c757d; font-size: .82rem; margin-top: .15rem; }

    .pay-order-rows {
        padding: .25rem 0;
    }
    .pay-order-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .65rem 1.25rem;
        font-size: .88rem;
        border-bottom: 1px solid #f8f8f8;
    }
    .pay-order-row span { color: #6c757d; }
    .pay-order-row strong { color: #212529; font-weight: 600; }

    .pay-order-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 1.25rem;
        background: #f0f6ff;
        border-top: 2px solid #0d6efd;
        font-weight: 700;
    }
    .pay-order-total span { color: #495057; font-size: .9rem; }
    .pay-order-total strong { font-size: 1.4rem; color: #0d6efd; }

    .pay-order-badges {
        display: flex;
        flex-direction: column;
        gap: .5rem;
        padding: 1rem 1.25rem;
        border-top: 1px solid #f0f0f0;
        font-size: .8rem;
        color: #6c757d;
    }
    .pay-order-badges span { display: flex; align-items: center; gap: .3rem; }

    /* ── Payment form shell (right column) ── */
    .pay-shell {
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 16px;
        padding: 1.75rem;
        box-shadow: 0 4px 16px rgba(0,0,0,.05);
    }

    .pay-methods-label {
        font-weight: 700;
        font-size: .9rem;
        color: #344054;
        margin-bottom: .75rem;
    }

    .pay-methods {
        display: flex;
        gap: .75rem;
        margin-bottom: 1.75rem;
    }
    .pay-method-btn {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .4rem;
        padding: .85rem .5rem;
        border: 2px solid #e9ecef;
        border-radius: 12px;
        background: transparent;
        cursor: pointer;
        font-size: .85rem;
        color: #495057;
        transition: border-color .15s, background .15s, color .15s;
    }
    .pay-method-btn i { font-size: 1.5rem; }
    .pay-method-btn.active, .pay-method-btn:hover {
        border-color: #0d6efd;
        background: #e7f1ff;
        color: #0d6efd;
    }

    .pay-panel { display: none; }
    .pay-panel.active { display: block; }

    .pay-card-preview {
        background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
        color: #fff;
        min-height: 160px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        box-shadow: 0 8px 24px rgba(0,0,0,.2);
    }
    .pay-card-chip i { font-size: 1.6rem; color: #ffd700; }
    .pay-card-number {
        font-size: 1.1rem;
        letter-spacing: .18em;
        font-family: monospace;
        text-align: center;
        margin: .5rem 0;
    }
    .pay-card-bottom { display: flex; justify-content: space-between; }
    .pay-card-label { font-size: .65rem; opacity: .7; text-transform: uppercase; letter-spacing: .05em; }
    .pay-card-value { font-size: .9rem; font-family: monospace; }

    .pay-form-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .pay-field { display: flex; flex-direction: column; gap: .35rem; }
    .pay-field label { font-size: .82rem; font-weight: 600; color: #344054; }
    .pay-field-full { grid-column: 1 / -1; }
    .pay-input-icon { position: relative; }
    .pay-input-suffix {
        position: absolute;
        left: .75rem;
        top: 50%;
        transform: translateY(-50%);
        color: #adb5bd;
        pointer-events: none;
    }

    .pay-paypal-logo {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: .4rem;
        font-size: 1.5rem;
        font-weight: 700;
        color: #003087;
        margin-bottom: 1.5rem;
    }

    .pay-wallet-balance {
        background: #d1fae5;
        border: 1px solid #a7f3d0;
        border-radius: 12px;
        padding: 1.25rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }
    .pay-wallet-balance strong { font-size: 1.3rem; color: #059669; }
    .pay-wallet-deduct {
        border: 1px solid #e9ecef;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 1rem;
    }
    .pay-wallet-row {
        display: flex;
        justify-content: space-between;
        padding: .75rem 1rem;
        font-size: .9rem;
        border-bottom: 1px solid #f0f0f0;
    }
    .pay-wallet-row:last-child { border-bottom: none; }

    .pay-sim-note {
        font-size: .8rem;
        color: #6c757d;
        background: #e7f5ff;
        border-radius: 8px;
        padding: .6rem .85rem;
        margin-top: .5rem;
        border: 1px solid #bee3f8;
    }

    .pay-submit-row {
        margin-top: 1.75rem;
        display: flex;
        flex-direction: column;
        gap: .75rem;
    }
    .pay-secure-badge {
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .8rem;
        color: #059669;
        justify-content: center;
    }
    .pay-submit-btn {
        width: 100%;
        padding: .9rem;
        font-size: 1.05rem;
        background: linear-gradient(135deg, #0d6efd, #0a58ca);
        color: #ffffff;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        transition: transform .15s, box-shadow .15s;
        box-shadow: 0 4px 16px rgba(13,110,253,.35);
    }
    .pay-submit-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 22px rgba(13,110,253,.45);
        color: #ffffff;
    }
    .pay-submit-btn:disabled { opacity: .7; transform: none; cursor: not-allowed; }

    /* Responsive */
    @@media (max-width: 767.98px) {
        .pay-checkout-grid { grid-template-columns: 1fr; }
        .pay-order-summary { position: static; }
    }
</style>

@section Scripts {
<script>
    const methodBtns = document.querySelectorAll('.pay-method-btn');
    const panels = document.querySelectorAll('.pay-panel');
    const methodInput = document.getElementById('methodInput');

    methodBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            methodBtns.forEach(b => b.classList.remove('active'));
            panels.forEach(p => p.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById(btn.dataset.panel).classList.add('active');
            methodInput.value = btn.dataset.method;
        });
    });

    const cardNumber = document.getElementById('cardNumber');
    cardNumber?.addEventListener('input', e => {
        let v = e.target.value.replace(/\D/g, '').substring(0, 16);
        e.target.value = v.replace(/(.{4})/g, '$1 ').trim();
        const masked = v.padEnd(16, '•');
        document.getElementById('cardPreviewNumber').textContent =
            masked.replace(/(.{4})/g, '$1 ').trim();
    });

    const cardExpiry = document.getElementById('cardExpiry');
    cardExpiry?.addEventListener('input', e => {
        let v = e.target.value.replace(/\D/g, '').substring(0, 4);
        if (v.length >= 3) v = v.substring(0,2) + '/' + v.substring(2);
        e.target.value = v;
        document.getElementById('cardPreviewExpiry').textContent = v || 'MM/YY';
    });

    const cardName = document.getElementById('cardName');
    cardName?.addEventListener('input', e => {
        document.getElementById('cardPreviewName').textContent = e.target.value || 'الاسم الكامل';
    });

    document.getElementById('payForm')?.addEventListener('submit', () => {
        const btn = document.getElementById('payBtn');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>جارٍ معالجة الدفع...';
    });
</script>
}
