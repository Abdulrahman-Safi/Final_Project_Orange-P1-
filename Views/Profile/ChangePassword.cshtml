@model ParkingReservation.Models.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "تغيير كلمة المرور";
}

<div class="profile-shell">
    <div class="customer-header">
        <div>
            <div class="customer-kicker">الأمان</div>
            <h1 class="customer-title">تغيير كلمة المرور</h1>
            <p class="customer-subtitle">اختر كلمة مرور قوية لا تقل عن 6 أحرف.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-right me-1"></i> رجوع
        </a>
    </div>

    <div class="profile-form-card">
        <form method="post" class="row g-4">
            <div asp-validation-summary="ModelOnly" class="text-danger col-12"></div>

            <div class="col-md-6">
                <label asp-for="CurrentPassword" class="form-label fw-bold">
                    <i class="bi bi-lock me-1 text-muted"></i> كلمة المرور الحالية *
                </label>
                <input asp-for="CurrentPassword" class="form-control auth-input" placeholder="••••••••" />
                <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
            </div>

            <div class="col-md-6"></div>

            <div class="col-md-6">
                <label asp-for="NewPassword" class="form-label fw-bold">
                    <i class="bi bi-lock-fill me-1 text-muted"></i> كلمة المرور الجديدة *
                </label>
                <input asp-for="NewPassword" class="form-control auth-input" placeholder="••••••••" />
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="ConfirmPassword" class="form-label fw-bold">
                    <i class="bi bi-lock-fill me-1 text-muted"></i> تأكيد كلمة المرور الجديدة *
                </label>
                <input asp-for="ConfirmPassword" class="form-control auth-input" placeholder="••••••••" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <div class="col-12">
                <div class="password-rules">
                    <strong><i class="bi bi-info-circle me-1"></i> متطلبات كلمة المرور:</strong>
                    <ul>
                        <li>6 أحرف على الأقل</li>
                        <li>حرف كبير واحد على الأقل (A-Z)</li>
                        <li>حرف صغير واحد على الأقل (a-z)</li>
                        <li>رقم واحد على الأقل (0-9)</li>
                        <li>رمز خاص واحد على الأقل (!@@#$...)</li>
                    </ul>
                </div>
            </div>

            <div class="col-12 d-flex gap-2">
                <button type="submit" class="btn primary-btn">
                    <i class="bi bi-shield-check me-1"></i> تغيير كلمة المرور
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
